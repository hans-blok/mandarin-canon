      "pad": "grondslagen/.normatief/",
      "omschrijving": "Constitutioneel, mensleesbaar. Normatieve basis: constitutie, doctrines, bronafleiding.",
      "runner_toegang": false
    },
    "laag2": {
      "pad": "grondslagen/.formeel/",
      "omschrijving": "Machine-readable. Formele ontologie (TTL) voor verificatie en controle.",
      "runner_toegang": false
    },
    "laag3": {
      "pad": "grondslagen/.bronnen/",
