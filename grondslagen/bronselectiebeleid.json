      "subpaden": {
        "ontologie": "grondslagen/.bronnen/ontologie.compact.md",
        "graph": "grondslagen/.bronnen/graph/",
        "rules": "grondslagen/.bronnen/rules/"
      }
    }
  },
  "principes": [
    "EC handelt input-gebonden en conditioneel.",
    "EC selecteert alleen op expliciete regels; nooit op inferentie of waarschijnlijkheid.",
    "EC wijzigt broninhoud niet; EC selecteert, reduceert, ordent en injecteert.",
