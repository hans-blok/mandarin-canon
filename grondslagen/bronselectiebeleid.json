        "kaderbronnen": {
          "verplicht": [
            {"bestand": "constitutie.md", "pad": "grondslagen/.normatief/constitutie.md", "laag": 1},
            {"bestand": "beleid-workspace.md", "laag": 1},
            {"bestand": "doctrine.bronhouding-en-exploratie.md", "pad": "grondslagen/.normatief/doctrine.bronhouding-en-exploratie.md", "laag": 1},
            {"bestand": "doctrine.traceability.md", "pad": "grondslagen/.normatief/doctrine.traceability.md", "laag": 1}
          ],
          "selectie": {
            "status_toegestaan": [
              "actief",
              "vers"
            ],
            "opnamevorm": "volledig"
          }
        },
        "referentiebronnen": {
          "verplicht_profielen": [
            "doctrine_selectie",
            "ontologie_selectie"
          ]
        },
        "werkbronnen": {
          "verplicht_profielen": [
            "parameters",
            "doelartefact",
            "graph_selectie"
          ]
        }
      },
      "doctrine_selectie": {
        "bron_id": "doctrine-manifest",
        "selectieregels": [
          "Neem alleen doctrines op die expliciet in doctrine_profiel van de doelintent zijn genoemd.",
          "Neem doctrine-bronhouding-en-exploratie.md altijd op als kaderbron.",
          "Neem geen doctrine op zonder eenduidige bronidentiteit.",
          "Neem geen doctrine op met status anders dan actief of vers."
        ]
      },
      "ontologie_selectie": {
        "bron_id": "ontologie",
        "optioneel": true,
        "selectieregels": [
          "Neem alleen ontologie op als doelintent een graph_selectieprofiel of ontologie_mapping vereist.",
          "Neem alleen de expliciet gevraagde concepten, relatietypen en mappings op.",
          "Bij ontbreken van conceptlijst of mapping: geen ontologie opnemen."
        ]
      },
      "parameters": {
        "verplicht": [
          "agent",
          "intent",
          "execution_file",
          "method"
        ]
      },
      "doelartefact": {
        "selectieregels": [
          "Neem alleen artefact op dat expliciet als werkbron voor de doelintent is opgegeven.",
          "Neem geen afgeleide of gerelateerde artefacten op zonder expliciete regel."
        ]
      },
      "graph_selectie": {
        "vereist_als": [
          "doelartefact_type == graph",
          "doelartefact_type == graph-json",
          "doelartefact_type == cypher-graph"
        ],
        "profiel_ref": "default_graph_selectie"
      }
    },
    "ecosysteem-coordinator.aggregeer-tasks": {
      "toelichting": "Aggregeert task-configuraties uitsluitend op basis van declaratieve value_stream-fasen in beleid-workspace.md.",
