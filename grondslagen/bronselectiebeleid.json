        "kaderbronnen": {
          "verplicht": [
            "beleid-workspace.md"
          ],
          "selectie": {
            "opnamevorm": "frontmatter-only"
          }
        },
        "werkbronnen": {
          "verplicht": [
            ".vscode/tasks/",
            "artefacten/**/tasks/"
          ]
        }
      },
      "selectieregels": [
        "Lees uitsluitend YAML frontmatter key value_stream-fasen uit beleid-workspace.md.",
        "Gebruik geen voorbeelden, illustraties of toelichtende tekst als configuratie-input.",
        "Scan alleen task-bestanden onder geconfigureerde value_stream-fasen.",
        "Bij ontbreken van value_stream-fasen: stop."
      ]
