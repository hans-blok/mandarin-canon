<?xml version="1.0" encoding="UTF-8"?>
<graphml xmlns="http://graphml.graphdrawing.org/graphml" xmlns:y="http://www.yworks.com/xml/graphml">
  <key id="d_label" for="node" attr.name="label" attr.type="string" />
